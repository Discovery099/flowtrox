//@version=6
// =============================================================================
// FLOWTOX_REGIME_01 — Adaptive Flow-Toxicity with Regime-Aware Sizing
// TradingView Pine Script v6 strategy port of coding_spec_strategy_01.md
//
// IMPORTANT — READ THIS (honest limitations vs. the Python spec):
//   The Python spec uses a fitted 3-state Gaussian Mixture / HMM for regime
//   posteriors and a training-set OLS HAR-RV fit. Pine Script CANNOT fit a GMM/
//   HMM or freeze a train-set OLS at runtime. Therefore this script is a
//   FAITHFUL port of the DETERMINISTIC parts (BVC toxicity, tick rule, Parkinson
//   realized variance, HAR forecast, inverse-vol sizing, entry/exit logic, no
//   pyramiding, time + regime early-exit, costs) and a TRANSPARENT PROXY for the
//   two unfittable parts:
//     1) HAR coefficients are INPUTS (defaults = my fitted ES values). Override
//        per instrument from the dashboard "Model" tab (HAR-RV section).
//     2) HMM posteriors are replaced by a logistic "pseudo-posterior" over the
//        same 5 observable features. This approximates the regime gate; it will
//        NOT reproduce the Python GMM exactly. Tune the alpha/beta inputs.
//   Use this to explore/visualize the logic on TradingView, not as a 1:1 clone
//   of the Python backtest. For exact results, use the Python engine.
// =============================================================================

strategy(
     title              = "FLOWTOX_REGIME_01",
     shorttitle         = "FLOWTOX_R01",
     overlay            = false,
     pyramiding         = 0,
     initial_capital    = 100000,
     default_qty_type   = strategy.fixed,
     default_qty_value  = 1,
     commission_type    = strategy.commission.cash_per_order,
     commission_value   = 1.25,   // per order; entry+exit ≈ $2.50 round-turn
     slippage           = 1,      // 1 tick per side (matches spec)
     calc_on_every_tick = false,
     process_orders_on_close = true)

// ---------------------------------------------------------------------------
// INPUTS
// ---------------------------------------------------------------------------
grpSig = "Signal thresholds (optimized params)"
tau1   = input.float(0.55, "τ1  toxic-continuation thresh", minval=0.0, maxval=1.0, step=0.01, group=grpSig)
tau2   = input.float(0.55, "τ2  toxic-reversal thresh",     minval=0.0, maxval=1.0, step=0.01, group=grpSig)
N      = input.int(15,     "N   max hold bars",             minval=1,   maxval=200, group=grpSig)
useRegimeExit = input.bool(true, "Enable regime early-exit (p < τ/2)", group=grpSig)

grpSize = "Position sizing (inverse-vol target)"
acctVal    = input.float(100000, "Account value ($)", group=grpSize)
sigmaTgt   = input.float(0.15,   "Target volatility (annual frac)", step=0.01, group=grpSize)
pointValue = input.float(50.0,   "Point value ($/pt)  ES=50 MES=5 MNQ=2 M2K=5 MGC=10 MCL=100", group=grpSize)
maxSize    = input.int(10,       "Max contracts", minval=1, group=grpSize)

grpHar = "HAR-RV forecast coefficients (fit in Python, paste here)"
harC  = input.float(0.0000254, "intercept c",  step=0.0000001, group=grpHar)
harBd = input.float(0.40,      "β daily",      step=0.01, group=grpHar)
harBw = input.float(0.55,      "β weekly",     step=0.01, group=grpHar)
harBm = input.float(0.001,     "β monthly",    step=0.001, group=grpHar)

grpReg = "Volatility regime"
useFixedThresh = input.bool(false, "Use fixed vol thresholds (else rolling pct)", group=grpReg)
p33In = input.float(0.00005, "fixed p33 thresh", step=0.00001, group=grpReg)
p67In = input.float(0.00015, "fixed p67 thresh", step=0.00001, group=grpReg)
regimeLookback = input.int(5000, "rolling percentile lookback (bars)", minval=200, group=grpReg)

grpHmm = "Regime pseudo-posterior (HMM proxy) — logistic weights"
zWin   = input.int(500, "Standardization window (bars)", minval=50, group=grpHmm)
aTox   = input.float(1.2, "α toxicity (continuation)",  step=0.1, group=grpHmm)
aMom   = input.float(1.0, "α momentum-align (continuation)", step=0.1, group=grpHmm)
aVol   = input.float(0.8, "α vol penalty (continuation)", step=0.1, group=grpHmm)
bTox   = input.float(1.2, "β toxicity (reversal)", step=0.1, group=grpHmm)
bMom   = input.float(1.0, "β momentum-oppose (reversal)", step=0.1, group=grpHmm)
bVol   = input.float(0.8, "β vol boost (reversal)", step=0.1, group=grpHmm)

grpWin = "Backtest window"
useTestWindow = input.bool(false, "Trade only after test-start date", group=grpWin)
testStart     = input.time(timestamp("2024-04-01 00:00"), "Test start", group=grpWin)

lookback = 20  // HMM_LOOKBACK from spec

// ---------------------------------------------------------------------------
// 2.1–2.4  BVC, tick rule, toxicity, Parkinson per-bar variance
// ---------------------------------------------------------------------------
rng      = high - low
bvc      = rng > 0 ? volume * (2 * close - low - high) / rng : 0.0
bvcSign  = bvc > 0 ? 1.0 : bvc < 0 ? -1.0 : 0.0
bvcDir   = bvcSign

tickDir  = close > close[1] ? 1.0 : close < close[1] ? -1.0 : 1.0
toxicity = bvcSign != 0 ? bvcSign * tickDir : 0.0   // -1 toxic, +1 informed, 0

parkinson = rng > 0 ? math.pow(math.log(high / low), 2) / (4 * math.log(2)) : 0.0

// ---------------------------------------------------------------------------
// 2.5  Realized variance grouped by ACTUAL session/day (instrument-agnostic)
// ---------------------------------------------------------------------------
var float[] dailyRVs = array.new_float()
var float   rvAccum  = 0.0
newDay = ta.change(time("D")) != 0

if newDay and bar_index > 0
    array.push(dailyRVs, rvAccum)
    rvAccum := 0.0
rvAccum += parkinson

f_lastmean(arr, n) =>
    sz  = array.size(arr)
    cnt = math.min(n, sz)
    s   = 0.0
    if cnt > 0
        for i = 0 to cnt - 1
            s += array.get(arr, sz - 1 - i)
    cnt > 0 ? s / cnt : na

rv1d = array.size(dailyRVs) > 0 ? array.get(dailyRVs, array.size(dailyRVs) - 1) : na
rv1w = f_lastmean(dailyRVs, 5)
rv1m = f_lastmean(dailyRVs, 22)

// ---------------------------------------------------------------------------
// 2.6  HAR volatility forecast (coefficients supplied as inputs)
// ---------------------------------------------------------------------------
harForecast = na(rv1d) ? na : math.max(harC + harBd * rv1d + harBw * rv1w + harBm * rv1m, 1e-12)

// ---------------------------------------------------------------------------
// 2.7  Volatility regime (0 low, 1 medium, 2 high)
// ---------------------------------------------------------------------------
p33 = useFixedThresh ? p33In : ta.percentile_linear_interpolation(harForecast, regimeLookback, 33)
p67 = useFixedThresh ? p67In : ta.percentile_linear_interpolation(harForecast, regimeLookback, 67)
volRegime = na(harForecast) ? 1 : harForecast <= p33 ? 0 : harForecast > p67 ? 2 : 1

// ---------------------------------------------------------------------------
// 2.8  Observable features (rolling over lookback=20)
// ---------------------------------------------------------------------------
isToxic = toxicity < 0 ? 1.0 : 0.0
f1 = ta.sma(isToxic, lookback)                       // toxicity rate
f2 = ta.sma(bvcSign, lookback)                       // mean BVC sign
f3 = math.log(1 + ta.sma(parkinson, lookback))       // log rolling Parkinson var
f4 = close - close[5]                                 // 5-bar momentum
f5 = volume / math.max(ta.sma(volume, lookback), 1)  // volume intensity

// ---------------------------------------------------------------------------
// 2.9  Regime pseudo-posterior (TRANSPARENT PROXY for the GMM/HMM)
//      Logistic over standardized features -> normalized 3-state posteriors.
// ---------------------------------------------------------------------------
f_z(x, w) =>
    sd = ta.stdev(x, w)
    sd > 0 ? (x - ta.sma(x, w)) / sd : 0.0

zTox = f_z(f1, zWin)
zVol = f_z(f3, zWin)
momAlign = math.sign(f4) == bvcSign and bvcSign != 0 ? 1.0 : -1.0

f_sig(x) => 1.0 / (1.0 + math.exp(-x))

pContRaw = f_sig(aTox * zTox + aMom * momAlign - aVol * zVol)
pRevRaw  = f_sig(bTox * zTox + bMom * (-momAlign) + bVol * zVol)
pNormRaw = math.max(0.05, 1.0 - math.max(pContRaw, pRevRaw))
pTot = pContRaw + pRevRaw + pNormRaw
pNormal = pNormRaw / pTot
pCont   = pContRaw / pTot   // hmm_state_1_posterior (toxic-continuation)
pRev    = pRevRaw  / pTot   // hmm_state_2_posterior (toxic-reversal)

// ---------------------------------------------------------------------------
// 3.6  Inverse-volatility position sizing (1..maxSize)
// ---------------------------------------------------------------------------
fVol = na(harForecast) ? na : math.sqrt(math.max(harForecast, 1e-12))
contractVolUsd = na(fVol) ? na : fVol * close * pointValue
sizeRaw = na(contractVolUsd) or contractVolUsd <= 0 ? 1.0 : (acctVal * sigmaTgt) / contractVolUsd
qty = math.max(1, math.min(maxSize, math.round(sizeRaw)))

// ---------------------------------------------------------------------------
// 3.7  Entry / exit logic (faithful to spec)
// ---------------------------------------------------------------------------
warmup = math.max(lookback, 25)
inWindow = not useTestWindow or time >= testStart
canTrade = not na(harForecast) and bar_index > warmup and inWindow and barstate.isconfirmed

longCond  = canTrade and pCont > tau1 and bvcDir > 0 and volRegime != 2
shortCond = canTrade and pRev  > tau2 and bvcDir < 0 and volRegime != 2

var int barsInTrade = 0
var float entryCont = na
var float entryRev  = na
flat = strategy.position_size == 0
isLong  = strategy.position_size > 0
isShort = strategy.position_size < 0

if not flat
    barsInTrade += 1

// Entries (no pyramiding: only when flat)
if flat and longCond
    strategy.entry("L", strategy.long, qty = qty)
    barsInTrade := 0
    entryCont := pCont
else if flat and shortCond
    strategy.entry("S", strategy.short, qty = qty)
    barsInTrade := 0
    entryRev := pRev

// Exits: time-based at N bars, or regime early-exit (p < τ/2)
if isLong
    timeExit   = barsInTrade >= N
    regimeOut  = useRegimeExit and pCont < tau1 / 2.0
    if timeExit or regimeOut
        strategy.close("L", comment = timeExit ? "time" : "regime")
if isShort
    timeExit   = barsInTrade >= N
    regimeOut  = useRegimeExit and pRev < tau2 / 2.0
    if timeExit or regimeOut
        strategy.close("S", comment = timeExit ? "time" : "regime")

// ---------------------------------------------------------------------------
// PLOTS — regime posteriors + vol regime (pane), markers on entries
// ---------------------------------------------------------------------------
plot(pNormal, "P(normal)",       color = color.new(color.gray, 0))
plot(pCont,   "P(toxic-cont)",   color = color.new(color.lime, 0))
plot(pRev,    "P(toxic-rev)",    color = color.new(color.orange, 0))
hline(tau1, "τ1", color = color.new(color.lime, 60), linestyle = hline.style_dashed)
hline(tau2, "τ2", color = color.new(color.orange, 60), linestyle = hline.style_dashed)
bgcolor(volRegime == 2 ? color.new(color.red, 90) : na, title = "High-vol regime (no-trade)")

plotchar(flat and longCond,  "long sig",  "▲", location.bottom, color.lime,   size = size.tiny)
plotchar(flat and shortCond, "short sig", "▼", location.top,    color.orange, size = size.tiny)
